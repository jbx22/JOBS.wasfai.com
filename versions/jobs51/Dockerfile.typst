FROM rust:1.92-bookworm AS builder
WORKDIR /build
COPY Cargo.toml Cargo.lock ./
COPY src ./src
COPY assets ./assets
RUN cargo build --release --bin mena-job-command-center

FROM debian:bookworm-slim
RUN useradd --system --uid 10001 renderer
WORKDIR /app
COPY --from=builder /build/target/release/mena-job-command-center /app/renderer
COPY public /app/public
RUN mkdir -p /app/data && chown -R renderer:renderer /app
ENV PORT=8080
USER renderer
EXPOSE 8080
ENTRYPOINT ["/app/renderer"]
